# Azure SQL Database
DATABASE_URL=mssql+pyodbc://user:password@your-server.database.windows.net/your-db?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes

# Kaggle (get from https://www.kaggle.com/settings)
KAGGLE_USERNAME=
KAGGLE_KEY=

# PredictHQ (get from https://www.predicthq.com — optional)
PREDICTHQ_API_KEY=

# SerpApi (get from https://serpapi.com — optional, free tier 100/month)
SERPAPI_KEY=

# Medici Hotels Trading DB (READ-ONLY access to medici-db)
MEDICI_DB_URL=mssql+pyodbc://prediction_readonly:password@medici-sql-server.database.windows.net/medici-db?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes

# Trading Analysis
TRADING_CACHE_TTL_MINUTES=5
TRADING_ANALYSIS_INTERVAL_MINUTES=30

# API Key for trading system integration
PREDICTION_API_KEY=

# Cache settings
CACHE_TTL_HOURS=24

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Model Settings
FORECAST_HORIZON=30
LOG_LEVEL=INFO
