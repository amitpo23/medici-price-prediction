# Azure SQL Database
# Format: mssql+pyodbc://USER:PASSWORD@SERVER.database.windows.net/DATABASE?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes
DATABASE_URL=mssql+pyodbc://user:password@your-server.database.windows.net/your-db?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Model Settings
FORECAST_HORIZON=30
LOG_LEVEL=INFO
