# ── Medici Price Prediction — Environment Variables ──
# Copy to .env and fill in your values.

# ── Core Database (required for live data) ───────────────
DATABASE_URL=mssql+pyodbc://user:password@server.database.windows.net/db?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes
MEDICI_DB_URL=mssql+pyodbc://prediction_readonly:password@medici-sql-server.database.windows.net/medici-db?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes

# ── API Authentication (required for deploy) ─────────────
PREDICTION_API_KEY=

# ── AI Intelligence (optional — falls back to rules) ─────
ANTHROPIC_API_KEY=
AI_INTELLIGENCE_ENABLED=true
CLAUDE_AI_MODEL=claude-haiku-4-20250514
CLAUDE_DEEP_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.2
AI_CACHE_TTL_SECONDS=1800
ANALYST_MAX_TOKENS=2048
ANALYST_CACHE_TTL=600

# ── External Data Sources (optional — enrichment) ────────
SEATGEEK_CLIENT_ID=
FRED_API_KEY=
PREDICTHQ_API_KEY=
MAKCORPS_API_KEY=
KAGGLE_USERNAME=
KAGGLE_KEY=
SERPAPI_KEY=
TICKETMASTER_API_KEY=

# ── Server Configuration ─────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ── Cache & Analytics ────────────────────────────────────
CACHE_TTL_HOURS=24
ANALYTICS_CACHE_TTL_HOURS=6
TRADING_CACHE_TTL_MINUTES=5
TRADING_ANALYSIS_INTERVAL_MINUTES=30

# ── Model Settings ───────────────────────────────────────
FORECAST_HORIZON=30
BOOTSTRAP_N_SAMPLES=200
